{
	"$schema": "https://opencode.ai/config.json",
	"compaction": {
		"auto": true,
		"prune": true,
		"reserved": 15000
	},
	"permission": {
		"edit": "ask",
		"bash": {
			"rm -rf *": "deny",
			"rm -r *": "deny",
			"git push --force*": "deny",
			"git reset --hard*": "deny",
			"git clean -fd*": "deny",
			"chmod -R *": "deny",
			"DROP *": "deny",
			"drop *": "deny",
			"*": "ask"
		}
	},
	"default_agent": "standard",
	"agent": {
		"default": {
			"disable": true
		},
		"standard": {
			"description": "Standard orchestrator — delegation-only; converses/plans and delegates execution to standard-* specialists.",
			"mode": "primary",
			"prompt": "{file:.opencode/agents/standard/standard.md}",
			"permission": {
				"edit": "deny",
				"bash": "deny",
				"question": "allow",
				"task": {
					"*": "deny",
					"standard-*": "allow",
					"explore": "allow",
					"code-reviewer": "allow",
					"codebase-architecture-mapper": "allow",
					"type-change-inconsistency-finder": "allow",
					"security-auditor": "allow",
					"performance-analyzer": "allow"
				}
			},
			"tools": {
				"bash": false,
				"write": false,
				"edit": false,
				"read": true,
				"grep": true,
				"glob": true,
				"webfetch": true
			}
		},
		"plan": {
			"disable": true
		},
		"build": {
			"disable": true
		},
		"full-auto": {
			"description": "Fully autonomous delegating orchestrator — routes execution to auto-* specialists and does not perform standalone writes/commands.",
			"mode": "primary",
			"prompt": "{file:.opencode/agents/auto/full-auto.md}",
			"permission": {
				"edit": "deny",
				"question": "allow",
				"bash": "deny",
